    <item>
      <title>LT/LoneStar Realistic Blinker Speed</title>
      <link>http://localhost:1313/docs/ets2_ats/ats/lt_lonestar_blinker/</link>
      <pubDate>Mon, 07 Apr 2025 00:00:00 +0000</pubDate>
      
      <guid>http://localhost:1313/docs/ets2_ats/ats/lt_lonestar_blinker/</guid>
